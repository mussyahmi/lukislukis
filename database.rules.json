{
  "rules": {
    "rooms": {
      ".read": "auth != null",
      "$roomCode": {
        ".read": true,
        ".write": "auth != null && (!data.exists() || data.child('players').child(auth.uid).exists() || data.child('adminId').val() === auth.uid)",
        "players": {
          "$playerId": {
            ".write": "auth != null && auth.uid === $playerId"
          }
        }
      }
    },
    "suggestions": {
      ".read": true,
      "$suggestionId": {
        ".write": "auth != null"
      }
    }
  }
}
